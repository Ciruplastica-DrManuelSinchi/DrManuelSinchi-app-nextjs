# ============================================
# BASE DE DATOS - NEON POSTGRESQL
# ============================================
# Reemplaza con tu URL de conexión de Neon
DATABASE_URL="postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================
# NEXTAUTH.JS
# ============================================
# Genera un secret seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-super-seguro-aqui-genera-uno-nuevo"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# EMAIL - RESEND
# ============================================
# Obtén tu API key en https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="Ciruplástica <noreply@ciruplastica.pe>"
