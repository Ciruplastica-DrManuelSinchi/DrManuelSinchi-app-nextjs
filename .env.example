# ============================================
# BASE DE DATOS - NEON POSTGRESQL
# ============================================
# Reemplaza con tu URL de conexión de Neon
DATABASE_URL="postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================
# NEXTAUTH.JS
# ============================================
# Genera un secret seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-super-seguro-aqui-genera-uno-nuevo"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# EMAIL - RESEND
# ============================================
# Obtén tu API key en https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="Ciruplástica <noreply@ciruplastica.pe>"

# ============================================
# GOOGLE OAUTH
# ============================================
# Configura en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# GOOGLE CALENDAR API
# ============================================
# Copia estos valores del archivo JSON descargado
GOOGLE_SERVICE_ACCOUNT_EMAIL="<nombre>@tu-proyecto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\//\\\n\n-----END PRIVATE KEY-----\n"

# ID del calendario del Dr. Sinchi (generalmente es su email)
GOOGLE_CALENDAR_ID="email@gmail.com"

# ============================================
# CULQI - PASARELA DE PAGOS
# ============================================
# Obtén tus llaves en https://panel.culqi.com
# Modo test:
NEXT_PUBLIC_CULQI_PUBLIC_KEY="pk_test_90667d0a57d45c48"
CULQI_SECRET_KEY="sk_test_5daf52c2c1b85891"

# Modo producción (reemplazar cuando esté listo):
# NEXT_PUBLIC_CULQI_PUBLIC_KEY="pk_live_xxxxx"
# CULQI_SECRET_KEY="sk_live_xxxxx"

# ============================================
# CLOUDINARY - ALMACENAMIENTO DE IMÁGENES
# ============================================
# Configura en https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"