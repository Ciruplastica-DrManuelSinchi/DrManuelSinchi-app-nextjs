// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  PATIENT
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
}

// ============================================
// MODELOS DE AUTENTICACIÓN (Auth.js Compatible)
// ============================================

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  emailVerified         DateTime?
  password              String?
  name                  String?
  phone                 String?
  image                 String?
  role                  UserRole       @default(PATIENT)
  status                AccountStatus  @default(PENDING_VERIFICATION)

  // Seguridad
  failedLoginAttempts   Int            @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?

  // Timestamps
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Relaciones Auth.js
  accounts              Account[]
  sessions              Session[]
  bookings              Booking[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("email") // email, password_reset

  createdAt  DateTime @default(now())

  @@index([token])
  @@map("verification_tokens")
}

// ============================================
// CATÁLOGO DE PROCEDIMIENTOS
// ============================================

model ProcedureCategory {
  id          String      @id @default(cuid())
  name        String      // "Cirugía Plástica Facial"
  slug        String      @unique  // "facial"
  urlPath     String?     // "cirugia-plastica-facial" - para construir URLs
  description String?
  order       Int         @default(0)
  isActive    Boolean     @default(true)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  procedures  Procedure[]
  realCases   RealCase[]

  @@index([isActive])
  @@index([order])
  @@map("procedure_categories")
}

model Procedure {
  id          String            @id @default(cuid())
  name        String            // "Rinoplastia"
  slug        String            @unique  // "rinoplastia"
  categoryId  String
  order       Int               @default(0)
  isActive    Boolean           @default(true)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  category    ProcedureCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([isActive])
  @@index([order])
  @@map("procedures")
}

// ============================================
// CASOS REALES (ANTES/DESPUÉS)
// ============================================

model RealCase {
  id              String            @id @default(cuid())
  procedureName   String            // "Rinoplastia"
  procedureSlug   String            // "rinoplastia" - para enlazar a la página
  categoryId      String
  patientInfo     String            // "Paciente femenina, 28 años"
  description     String            @db.Text
  beforeImage     String            // URL de imagen antes
  afterImage      String            // URL de imagen después
  order           Int               @default(0)
  isActive        Boolean           @default(true)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  category        ProcedureCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([isActive])
  @@index([order])
  @@map("real_cases")
}

// ============================================
// SISTEMA DE RESERVAS
// ============================================

enum BookingStatus {
  AWAITING_PAYMENT  // Esperando pago (30 min límite)
  PENDING           // Pagado, esperando confirmación del doctor
  CONFIRMED         // Confirmada por el doctor
  CANCELLED         // Cancelada
  COMPLETED         // Completada
  EXPIRED           // Expirada (no se completó el pago a tiempo)
}

enum PaymentMethod {
  CULQI_CARD
  YAPE
  WHATSAPP_ONLY
  SIMULATED       // Solo para desarrollo/pruebas
}

enum DocumentType {
  DNI
  CE              // Carnet de Extranjería
  PASSPORT
}

model Booking {
  id                String        @id @default(cuid())
  userId            String

  // Datos personales del paciente
  birthDate         DateTime?
  documentType      DocumentType?
  documentNumber    String?
  address           String?
  city              String?
  occupation        String?

  // Datos de la cita
  procedureId       String
  procedureName     String
  procedureCategory String
  date              DateTime
  timeSlot          String
  weight            Decimal?      @db.Decimal(5, 2)  // Peso en kg (ej: 75.50)
  height            Decimal?      @db.Decimal(5, 2)  // Talla en cm (ej: 170.00)
  referralSource    String?       // ¿Cómo se enteró de nosotros?
  message           String?       @db.Text

  // Estado y pago
  status            BookingStatus @default(AWAITING_PAYMENT)
  paymentDeadline   DateTime?     // Fecha límite para completar el pago (30 min desde creación)
  calendarEventId   String?       // ID del evento en Google Calendar

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment           Payment?

  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([paymentDeadline])
  @@map("bookings")
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  culqiChargeId String?
  status        String        @default("pending") // pending, completed, failed

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("payments")
}

// ============================================
// SISTEMA DE BLOG
// ============================================

enum BlogStatus {
  DRAFT         // Borrador
  PUBLISHED     // Publicado
  ARCHIVED      // Archivado
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String   // "Cirugía Plástica", "Cuidados", "Novedades"
  slug        String   @unique
  description String?
  color       String?  // Color para badges (ej: "#8B5CF6")
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       BlogPost[]

  @@index([isActive])
  @@index([order])
  @@map("blog_categories")
}

model BlogPost {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  excerpt       String       @db.Text     // Resumen corto para listados
  content       String       @db.Text     // Contenido completo (HTML o Markdown)
  coverImage    String?                   // URL de imagen de portada
  categoryId    String?
  authorName    String       @default("Dr. Manuel Sinchi")
  authorImage   String?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Estado y visibilidad
  status        BlogStatus   @default(DRAFT)
  featured      Boolean      @default(false)  // Destacado en home
  publishedAt   DateTime?

  // Métricas
  views         Int          @default(0)
  readingTime   Int?                         // Tiempo de lectura en minutos

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  category      BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([publishedAt])
  @@map("blog_posts")
}

